<?xml version="1.0" encoding="utf-8"?>
<!-- Launcher icon: the mark on a cream field, 84dp inside the 108dp square so
     it stays clear of the rounding launchers apply. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/cream" />
    <item
        android:drawable="@drawable/logo_lighthouse"
        android:gravity="center"
        android:width="84dp"
        android:height="84dp"
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />
</layer-list>
