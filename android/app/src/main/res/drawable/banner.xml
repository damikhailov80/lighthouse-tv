<?xml version="1.0" encoding="utf-8"?>
<!-- Leanback launcher banner. The insets both centre the 140dp mark and give
     the layer list its intrinsic 320x180dp: 90+140+90 by 20+140+20. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/cream" />
    <item
        android:drawable="@drawable/logo_lighthouse"
        android:gravity="center"
        android:width="140dp"
        android:height="140dp"
        android:left="90dp"
        android:top="20dp"
        android:right="90dp"
        android:bottom="20dp" />
</layer-list>
