<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ draws its own splash screen at launch and ignores
         windowBackground for it: without these attributes the system shows the
         icon on a white field before the activity is even created. -->
    <style name="AppTheme" parent="AppTheme.Base">
        <item name="android:windowSplashScreenBackground">@color/night</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
    </style>
</resources>
